{
  "manifest_version": 3,
  "name": "Injection CSS",
  "version": "1.0",
  "description": "Injecte du CSS personnalisé sur un site web.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.omnivox.ca/*"],
      "css": ["darkmode.css"]
    }
  ]
}
