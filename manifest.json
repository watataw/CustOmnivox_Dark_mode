{
  "manifest_version": 3,
  "name": "CustOmnivox - Dark mode",
  "version": "1.2",
  "description": "Theme sombre personnalisable pour Omnivox",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.omnivox.ca/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CustOmnivox - Dark mode",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.omnivox.ca/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}