{
  "manifest_version": 3,
  "name": "CustOmnivox - Dark mode",
  "version": "1.1",
  "description": "Theme sombre pour Omnivox",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.omnivox.ca/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Omnivox Theme"
  },
  "content_scripts": [
    {
      "matches": ["https://*.omnivox.ca/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}